{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cmake",
            "label": "CMake: 配置",
            "command": "configure",
            "problemMatcher": [],
            "detail": "CMake 模板 配置 任务",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "C:\\TDM-GCC-64\\bin\\gcc.exe",
            "args": [
    "-fdiagnostics-color=always",
    "-g",
    "${workspaceFolder}\\main.c",
    "${workspaceFolder}\\model\\admin_model.c",
    "${workspaceFolder}\\model\\teacher_model.c",
    "${workspaceFolder}\\model\\student_model.c",
    "${workspaceFolder}\\view\\view.c",
    "${workspaceFolder}\\controller\\controller.c",
    "-I",
    "${workspaceFolder}",
    "-o",
    "${workspaceFolder}\\main.exe"
],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ]
}